# Preferred provider (Anthropic via Lava gateway)
LAVA_API_KEY=aks_live_WSK0kfmH5GtZwfEsNRTDUQa1wxGnEgIGO-XR8B6ak_jhvmAsTTWbBM3
LAVA_BASE_URL=https://api.lava.so/v1/forward
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional direct providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=

TWITTER_BEARER_TOKEN=
NEWSAPI_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
APIFY_API_TOKEN=
APIFY_TWITTER_ACTOR_ID=apidojo/twitter-scraper-lite
# Optional authenticated X timeline scraping via python x-timeline-scraper.
# 1) pip install xtimeline
# 2) capture/prepare curl.txt per project docs, then set its path below.
XTIMELINE_CURL_PATH=/absolute/path/to/who-changed-app/server/curl.txt
XTIMELINE_PYTHON_BIN=python3
XTIMELINE_TIMEOUT_MS=45000
# If true, backend attempts to auto-capture the needed X GraphQL request
# via Playwright when scraping starts (no manual DevTools copy each search).
XTIMELINE_AUTO_CAPTURE=true
XTIMELINE_USER_DATA_DIR=/absolute/path/to/playwright-user-data-dir
XTIMELINE_HEADLESS=true
XTIMELINE_BROWSER_CHANNEL=chrome
XTIMELINE_CAPTURE_TIMEOUT_MS=60000
ENABLE_BACKGROUND_ANALYSIS=false
PORT=3001
VISION_SCREENSHOT_MAX=16
# Cap posts used per analysis run (speed vs depth). Typical: 800-1200. Max: 3200.
ANALYSIS_MAX_POSTS=1200
# Max tweets to keep for CSV export endpoint (3-year scrape flow).
EXPORT_MAX_POSTS=10000
# Minimum real tweets required before analysis runs.
MIN_ANALYSIS_TWEETS=240
MIN_TOPIC_COVERAGE_TOPICS=5
MIN_TOPIC_HITS_PER_TOPIC=2
# Set true to ignore saved tweet corpus and re-fetch (still requires Twitter/archive keys)
FORCE_RESCRAPE=false
