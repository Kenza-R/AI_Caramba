# Preferred provider (Anthropic via Lava gateway)
LAVA_API_KEY=
LAVA_BASE_URL=https://api.lava.so/v1/forward
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional direct providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=

TWITTER_BEARER_TOKEN=
NEWSAPI_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
APIFY_API_TOKEN=
APIFY_TWITTER_ACTOR_ID=
PORT=3001
VISION_SCREENSHOT_MAX=16
USE_MOCK_DATA=false
USE_MOCK_AI=false
# Set true to ignore saved tweet corpus and re-fetch (still requires Twitter/archive keys)
FORCE_RESCRAPE=false
