# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Twitter accounts for twscrape (add up to 5 for rotation)
# Use throwaway accounts — not your main account
TW_USER_1=your_twitter_username
TW_PASS_1=your_twitter_password
TW_EMAIL_1=your_email@example.com
TW_EMAIL_PASS_1=your_email_password   # optional, needed for some 2FA flows

# TW_USER_2=...
# TW_PASS_2=...
# TW_EMAIL_2=...
